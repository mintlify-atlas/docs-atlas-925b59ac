  "keyFeatures": [
    "Invoicing with series, numbering, and status management",
    "Quotes/budgets that can be converted to invoices",
    "Delivery notes (albaranes) with grouped billing",
    "Expense management / purchase invoices",
    "Treasury module with due-date tracking and cobros",
    "Visual PDF designer with WYSIWYG editor and live preview",
    "AEAT tax-identity validation (individual and bulk up to 20,000 NIFs)",
    "Multi-company support with role-based access (superadmin/admin/user)",
    "SMTP email integration for sending documents directly",
    "Excel and PDF report exports",
    "PWA-ready React 19 frontend with Tailwind CSS",
    "PostgreSQL backend via Prisma + Supabase compatibility",
    "Vercel-ready deployment for both frontend and backend"
  ],
